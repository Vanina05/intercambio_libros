h2>Editar Perfil</h2>
<%= form_with model: @user, local: true do |f| %>
  <%= f.label :name %><br>
  <%= f.text_field :name %><br>

  <%= f.label :email %><br>
  <%= f.email_field :email %><br>

  <%= f.label :city %><br>
  <%= f.text_field :city %><br>

  <%= f.label :description %><br>
  <%= f.text_area :description %><br>

  <%= f.submit "Actualizar", class: "btn btn-primary" %>
<% end %>