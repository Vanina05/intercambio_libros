<h2>Perfil de <%= @user.name %></h2>
<p><strong>Ciudad:</strong> <%= @user.city %></p>
<p><strong>Descripción:</strong> <%= @user.description %></p>

<% if current_user == @user %>
  <%= link_to "Editar perfil", edit_user_path(@user) %>
<% end %>

<h3>Notificaciones</h3>

<% if @user.notifications.any? %>
  <ul>
    <% @user.notifications.order(created_at: :desc).each do |notification| %>
      <li style="<%= 'font-weight: bold;' unless notification.read %>">
        <%= notification.message %>
        <% unless notification.read %>
          <%= button_to "Marcar como leída", mark_read_notification_path(notification), method: :patch %>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>No tienes notificaciones.</p>
<% end %>

<%= link_to 'Volver al inicio', root_path, class: 'btn btn-primary' %>