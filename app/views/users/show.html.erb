<div class="container pt-5 pb-5">
  <div class="card border-0 shadow-sm mb-4" style="border-radius: 20px; background-color: white;">
    <div class="card-body p-4 d-flex justify-content-between align-items-center flex-wrap">
      <div>
        <h1 class="fw-bold text-dark mb-1">Perfil de <%= @user.name %></h1>
        <p class="text-muted mb-2"><i class="bi bi-geo-alt-fill me-1"></i><%= @user.city %></p>
        <p class="mb-0 text-secondary" style="max-width: 600px;"><%= @user.description %></p>
      </div>
      
      <div class="d-flex gap-2 mt-3 mt-md-0">
        <% if current_user == @user %>
          <%= link_to edit_user_path(@user), class: "btn btn-outline-primary fw-bold px-4" do %>
            <i class="bi bi-pencil-square me-1"></i> Editar perfil
          <% end %>

          <%= button_to logout_path, method: :delete, class: "btn btn-danger d-flex align-items-center justify-content-center gap-2 shadow-sm w-100" do %>
            <i class="bi bi-box-arrow-right"></i> Cerrar sesión
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <% if current_user == @user %>
    <div class="mb-5">
      <% unread_count = @unread_count %>
      
      <div class="d-flex align-items-center justify-content-between mb-3">
        <div class="d-flex align-items-center gap-3">
          <h3 class="fw-bold m-0">Notificaciones</h3>
          <%= link_to exchange_requests_path, class: "btn btn-primary position-relative fw-bold px-4 shadow-sm", style: "border-radius: 12px;" do %>
            Solicitudes de Intercambio
            <% if unread_count > 0 %>
              <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger shadow">
                <%= unread_count %>
              </span>
            <% end %>
          <% end %>
        </div>
      </div>

      <% if @notifications.any? %>
        <div class="list-group shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
          <% @notifications.each do |notification| %>
            <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-3 border-0 <%= 'bg-light fw-bold border-start border-primary border-4' unless notification.read %>">
              <div class="d-flex align-items-center gap-3">
                <i class="bi <%= notification.read ? 'bi-envelope-open text-muted' : 'bi-envelope-fill text-primary' %>"></i>
                <div class="d-flex flex-column">
                  <span><%= notification.message %></span>
                  <%= link_to "Ir a mis solicitudes para responder", exchange_requests_path, class: "small text-primary text-decoration-none fw-normal mt-1" %>
                </div>
              </div>
              
              <div class="d-flex gap-2">
                <% unless notification.read %>
                  <%= button_to mark_read_notification_path(notification), method: :patch, class: "btn btn-sm btn-light border", style: "border-radius: 8px;" do %>
                    <i class="bi bi-check2"></i> Marcar leída
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="alert alert-light border shadow-sm text-center py-4" style="border-radius: 15px;">
          <p class="text-muted mb-0">No tienes notificaciones pendientes.</p>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @notifications.any? %>
    <div class="list-group shadow-sm border-0" style="border-radius: 15px; overflow: hidden;">
      <% @notifications.each do |notification| %>
        <%# ... tu código actual de las notificaciones ... %>
      <% end %>
    </div>
    
    <%# Mensaje de ayuda visual %>
    <div class="text-center mt-2">
      <small class="text-muted">Mostrando notificaciones pendientes y las últimas 5 leídas.</small>
    </div>
  <% end %>

  <hr class="my-5 opacity-25">

  <h3 class="fw-bold mb-4">Libros publicados</h3>

  <% if @user.books.any? %>
    <div class="row">
      <% @user.books.each do |book| %>
        <div class="col-md-4 mb-4">
          <div class="card h-100 border-0 shadow-sm hover-card" style="border-radius: 15px; overflow: hidden;">
            <% if book.image.attached? %>
              <%= image_tag book.image, class: "card-img-top", style: "height: 200px; object-fit: cover;" %>
            <% else %>
              <div class="bg-light text-center d-flex align-items-center justify-content-center" style="height: 200px;">
                <span class="text-muted">Sin portada</span>
              </div>
            <% end %>

            <div class="card-body">
              <span class="badge bg-info-subtle text-info mb-2"><%= book.genre %></span>
              <h5 class="card-title fw-bold">
                <%= link_to book.title, book_path(book), class: "text-decoration-none text-dark" %>
              </h5>
              <p class="text-muted small mb-1"><strong>Autor:</strong> <%= book.author %></p>
              
              <% if book.synopsis.present? %>
                <p class="card-text small text-secondary"><%= truncate(book.synopsis, length: 80) %></p>
              <% end %>

              <hr class="my-3 opacity-25">
              <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted small">Año: <%= book.year %></span>
                <%= link_to "Ver más", book_path(book), class: "btn btn-sm btn-outline-primary" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-5">
      <p class="text-muted italic">Este usuario no ha publicado libros todavía.</p>
    </div>
  <% end %>

  <div class="d-flex justify-content-between align-items-center mt-5">
    <%= link_to root_path, class: 'btn btn-outline-secondary d-flex align-items-center gap-2' do %>
      <i class="bi bi-arrow-left"></i> Volver al inicio
    <% end %>
  </div>
</div>

<style>
  .hover-card { transition: transform 0.2s ease; }
  .hover-card:hover { transform: translateY(-5px); }
</style>