<div class="container pb-5">
  <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 20px; background-color: white;">
    <div class="row g-0">
      
      <div class="col-md-5 bg-light d-flex align-items-center justify-content-center" style="min-height: 400px;">
        <% if @book.image.attached? %>
          <%= image_tag @book.image, class: "img-fluid shadow-sm", style: "width: 100%; height: 100%; object-fit: cover;" %>
        <% else %>
          <div class="text-center text-muted">
            <i class="bi bi-book" style="font-size: 4rem; display: block;"></i>
            <span>Sin portada disponible</span>
          </div>
        <% end %>
      </div>

      <div class="col-md-7">
        <div class="card-body p-5">
          <div class="mb-4">
            <span class="badge bg-primary-subtle text-primary mb-2 px-3 py-2"><%= @book.genre %></span>
            <h1 class="display-5 fw-bold text-dark"><%= @book.title %></h1>
            <p class="lead text-secondary">de <strong class="text-dark"><%= @book.author %></strong></p>
          </div>

          <div class="row mb-4">
            <div class="col-6">
              <p class="mb-1 text-muted small uppercase fw-bold">Año de publicación</p>
              <p class="fs-5 text-dark"><%= @book.year %></p>
            </div>
            <div class="col-6">
              <p class="mb-1 text-muted small uppercase fw-bold">Publicado por</p>
              <p class="fs-5"><%= link_to @book.user.name, user_path(@book.user), class: "text-decoration-none fw-bold" %></p>
            </div>
          </div>

          <hr class="my-4 opacity-25">

          <div class="mb-4">
            <h5 class="fw-bold">Sinopsis</h5>
            <p class="text-muted" style="line-height: 1.6;"><%= @book.synopsis %></p>
          </div>

          <div class="mb-5">
            <h5 class="fw-bold">Detalles adicionales</h5>
            <p class="text-muted"><%= @book.details %></p>
          </div>

          <div class="d-flex flex-wrap gap-3 align-items-center">
  
            <%# 1. Lógica para el visitante (Solicitar intercambio) %>
            <% if current_user && current_user != @book.user %>
              <% if @book.available %>
                <%= form_with url: exchange_requests_path, method: :post do |f| %>
                  <%= hidden_field_tag :book_id, @book.id %>
                  <%= f.submit "Solicitar intercambio", class: "btn btn-primary btn-lg px-4 py-2 shadow-sm fw-bold" %>
                <% end %>
              <% else %>
                <button class="btn btn-secondary btn-lg px-4 py-2" disabled>No disponible para intercambio</button>
              <% end %>
            <% end %>

            <%# 2. Lógica para el dueño (Gestionar disponibilidad) %>
            <% if current_user == @book.user %>
              <div class="d-flex gap-2 w-100 mt-2">
                <% if @book.available %>
                  <%= button_to toggle_availability_book_path(@book), method: :patch, class: "btn btn-warning btn-lg px-4 fw-bold" do %>
                    <i class="bi bi-pause-circle me-1"></i> Marcar como NO disponible
                  <% end %>
                <% else %>
                  <%= button_to toggle_availability_book_path(@book), method: :patch, class: "btn btn-outline-success btn-lg px-4 fw-bold" do %>
                    <i class="bi bi-play-circle me-1"></i> Marcar como disponible
                  <% end %>
                <% end %>
                
                <%= link_to "Editar libro", edit_book_path(@book), class: "btn btn-success btn-lg px-4" %>
                <%= button_to "Eliminar libro", book_path(@book), method: :delete, data: { confirm: "¿Estás seguro?" }, class: "btn btn-outline-danger btn-lg px-4" %>
              </div>
            <% end %>

            <%= link_to 'Volver al inicio', root_path, class: 'btn btn-link text-secondary text-decoration-none' %>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>