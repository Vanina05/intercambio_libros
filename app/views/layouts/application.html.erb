<!DOCTYPE html>
<html>
  <head>
    <title>Intercambio de Libros</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", media: "all", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <!-- CSS Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-..." crossorigin="anonymous">

    <!-- JS Bootstrap Bundle (incluye Popper) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-..." crossorigin="anonymous"></script>
  </head>

  <body>
    <header>
      <nav>
        <% if current_user %>
          <p>Bienvenido!! <%= current_user.nombre %> | 
            <%= button_to "Cerrar sesión", logout_path, method: :delete, class:"btn btn-danger" %>
          </p>
        <% else %>
          <%= link_to "Iniciar sesión", login_path, class:"btn btn-primary" %> |
          <%= link_to "Registrarse", new_user_path, class:"btn btn-secondary" %>
        <% end %>
      </nav>
    </header>

    <%= yield %>
  </body>
</html>